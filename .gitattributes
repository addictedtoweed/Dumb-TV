# Force LF on text sources so Makefile/heredocs work under MSYS2 + WSL
*.v        text eol=lf
*.sv       text eol=lf
*.py       text eol=lf
*.sh       text eol=lf
*.c        text eol=lf
*.h        text eol=lf
*.S        text eol=lf
*.ld       text eol=lf
Makefile   text eol=lf
*.md       text eol=lf
